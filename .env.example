# Required
TELEGRAM_BOT_TOKEN=your-bot-token       # Telegram bot token (from @BotFather)
GEMINI_API_KEY=your-api-key             # Gemini API key (from aistudio.google.com)
ADMIN_TELEGRAM_ID=123456789             # Your Telegram user ID (send /start to @userinfobot)
GOOGLE_CLIENT_ID=your-client-id         # Google OAuth Client ID
GOOGLE_CLIENT_SECRET=your-secret        # Google OAuth Client Secret
